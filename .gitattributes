# Normalize line endings for text files.
* text=auto eol=lf
# Unity YAML scene/prefab/asset files are text — leave them out of LFS so
# diffs and merges work. (Unity > Editor > Asset Serialization = Force Text.)
*.unity   text merge=union
*.prefab  text merge=union
*.asset   text merge=union
*.meta    text merge=union
*.mat     text merge=union
*.anim    text merge=union
*.controller text merge=union
*.lighting text merge=union
*.physicMaterial text merge=union
*.physicsMaterial2D text merge=union
*.preset  text merge=union
*.terrainlayer text merge=union
*.spriteatlas text merge=union
*.shadergraph text merge=union
*.shadersubgraph text merge=union
*.shader  text
*.cginc   text
*.compute text
*.hlsl    text
*.glsl    text
*.cs      text diff=csharp
*.json    text
*.md      text
*.txt     text
*.xml     text
*.yaml    text
*.yml     text
*.gitattributes text
*.gitignore text
# --- Git LFS: binary assets ---
