# Auto-HTTPS (Let's Encrypt) for the OVH hostname, fronting the Go backend
# (profiles/leaderboard/matchmaking/results). The battle server is reached directly over
# plain ws:// on :8081 (Unity's Mono TLS can't do wss), so it's NOT proxied here.
vps-7d32ac6f.vps.ovh.us {
	encode gzip
	reverse_proxy backend:8080
}
